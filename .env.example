# ============================================================
# i2i-yield-watch — Environment Variables
# ============================================================
# This file is the single source of truth for runtime
# config. The real values live in .env (encrypted via
# git-crypt and committed to the repo).
#
# To bootstrap a fresh checkout:
#   1. Copy this file to .env:
#        cp .env.example .env
#   2. Fill in your secrets.
#   3. If you've exported the git-crypt key, unlock it:
#        git-crypt unlock /path/to/git-crypt-key
#
# For GitHub Actions, see .github/workflows/scrape.yml.
# The .env file is decrypted from a base64 secret named
# GIT_CRYPT_KEY in CI.
# ============================================================

# --- SCRAPER SETTINGS ---
# Interest rate threshold (percent). Loans with rate
# strictly greater than this are notified.
NOTIFY_RATE_THRESHOLD=50

# Priority thresholds (informational only — used by
# the yield scorer to label loan priority)
HIGH_PRIORITY_RATE_THRESHOLD=70
MEDIUM_PRIORITY_RATE_THRESHOLD=50

# Maximum Show More clicks (Playwright fallback safety)
MAX_SHOW_MORE_CLICKS=150

# Use Playwright DOM scraper instead of the HTTP API.
# Leave false in production — the API fast path is ~1s;
# Playwright can take minutes. CI always installs
# Playwright so the automatic fallback still works
# when the API is unreachable.
USE_PLAYWRIGHT_FALLBACK=false

# --- FIREBASE (FIRESTORE) ---
# All persistent state lives in Cloud Firestore. The
# scraper authenticates with a service account; the
# dashboard reads publicly via the JS SDK + RLS.
#
# Local dev: drop the service account JSON at the project
# root as i2i-yield-watch-sa.json (git-crypt encrypted).
#
# CI: set FIREBASE_SA_JSON to the full JSON contents in
# a GitHub Secret. The workflow writes it to a temp file
# and points FIREBASE_SA_PATH at it.
FIREBASE_SA_PATH=i2i-yield-watch-sa.json
# FIREBASE_SA_JSON={"type":"service_account",...}  # CI only

# --- TELEGRAM NOTIFICATION ---
TELEGRAM_ENABLED=false

# Get from @BotFather on Telegram:
#   1. Open Telegram, search for @BotFather
#   2. Send /newbot and follow the prompts
#   3. Copy the bot token (format: 123456:ABC-DEF...)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get your Chat ID:
#   1. Start a chat with your bot (send /start)
#   2. Visit in browser:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#   3. Look for "chat":{"id": XXXXXXXX}
#   4. Copy that numeric ID
TELEGRAM_CHAT_ID=your_chat_id_here

# --- EMAIL NOTIFICATION (Gmail SMTP) ---
EMAIL_ENABLED=false

# Your Gmail address (the sender)
EMAIL_FROM=your_gmail@gmail.com

# Gmail App Password — NOT your account password!
# To generate:
#   1. Enable 2FA on your Google account
#      (myaccount.google.com → Security → 2FA)
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Select app "Mail" and device "Other"
#   4. Copy the 16-character password (no spaces)
EMAIL_APP_PASSWORD=your_16_char_app_password

# Where to send notifications (can be same as FROM)
EMAIL_TO=your_email@gmail.com

# --- DISCORD NOTIFICATION ---
DISCORD_ENABLED=false

# Create a webhook in your Discord server:
#   1. Open Discord → your server
#   2. Server Settings → Integrations → Webhooks
#   3. Click "New Webhook"
#   4. Name it "i2i Yield Watch"
#   5. Select the channel for notifications
#   6. Click "Copy Webhook URL"
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# --- NTFY.SH NOTIFICATION ---
# Free, open-source HTTP pub-sub service. Subscribe to
# the topic in the ntfy mobile/desktop/web app, then
# this notifier POSTs to <NTFY_BASE_URL>/<NTFY_TOPIC>.
#
# The topic name is the password — pick something
# unguessable. Self-hosting: set NTFY_BASE_URL to your
# server, e.g. https://ntfy.yourdomain.com
NTFY_ENABLED=false
NTFY_BASE_URL=https://ntfy.sh
NTFY_TOPIC=i2i-yield-watch-your-secret-topic
# Optional: only for access-controlled self-hosted ntfy
# NTFY_USER=your_username
# NTFY_PASSWORD=your_password

# --- DASHBOARD ---
# Your GitHub Pages URL (set after first deployment)
# Format: https://<USERNAME>.github.io/i2i-yield-watch/
DASHBOARD_URL=https://chirag127.github.io/i2i-yield-watch/
